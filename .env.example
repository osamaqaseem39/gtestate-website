# API base URL (defaults to production if not set)
NEXT_PUBLIC_API_URL=https://estate-server-nine.vercel.app
# Public site URL (for your own links). On the API, add this origin to CORS_ORIGINS if it is not localhost, *.vercel.app, or gtestates.com.pk.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# SMTP — Sending inquiry emails directly from the website (Server Actions)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=info@gtestates.com.pk
SMTP_PASS=your-password
SMTP_FROM="GT Estate <noreply@gtestates.com.pk>"
INQUIRY_NOTIFY_EMAIL=info@gtestates.com.pk
